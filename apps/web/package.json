{
  "name": "@the-tile/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "build-agent-context": "tsx scripts/build-agent-context.ts",
    "sync-data": "tsx scripts/sync-data.ts",
    "sync-seed": "tsx scripts/sync-seed.ts",
    "validate-seed": "tsx scripts/validate-seed.ts",
    "generate-redirects": "tsx scripts/generate-redirects.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:staging": "wrangler d1 migrations apply the-tile-staging --remote",
    "db:migrate:prod": "wrangler d1 migrations apply the-tile-prod --remote",
    "postinstall": "tsx scripts/sync-data.ts && tsx scripts/build-agent-context.ts && tsx scripts/generate-redirects.ts"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.0.20",
    "@fontsource/inter": "^5.0.20",
    "@hookform/resolvers": "^3.9.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "lucide-react": "^0.468.0",
    "next": "14.2.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.54.0",
    "react-markdown": "^9.0.1",
    "rehype-sanitize": "^6.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "wrangler": "^3.90.0",
    "@cloudflare/workers-types": "^4.20240924.0"
  },
  "engines": {
    "node": ">=20"
  }
}
