# Server-only. Never prefix with NEXT_PUBLIC_.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
MONTHLY_TOKEN_CAP=2000000

# --- Phase 1 optional — empty values disable the integration ---
# Cloudflare Turnstile (bot gate on contact form + first agent message)
TURNSTILE_SECRET=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Resend (transactional lead email)
RESEND_API_KEY=
LEAD_INBOX=hello@the-tile.com
# Salt for SHA-256 IP hashing (rate-limit keys; not identity)
IP_HASH_SALT=change-me
# Plausible analytics domain (script injected only when set)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Sentry DSN (no-op unless set; full integration is Phase 2)
NEXT_PUBLIC_SENTRY_DSN=
# Canonical site URL (used by metadata, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://www.the-tile.com
